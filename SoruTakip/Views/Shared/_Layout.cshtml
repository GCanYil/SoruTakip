<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SoruTakip</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        :root {
            --cream: #F5F0E8;
            --warm-white: #FAF8F4;
            --burgundy: #7B2D42;
            --burgundy-light: #A63D58;
            --burgundy-dark: #5C1F30;
            --slate: #3D4552;
            --slate-light: #6B7585;
            --border: #E2DAD0;
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--cream);
            color: var(--slate);
            font-family: system-ui, -apple-system, sans-serif;
            min-height: 100vh;
        }

        .navbar-st {
            background-color: var(--warm-white);
            border-bottom: 0.5px solid var(--border);
            padding: 0.75rem 1.5rem;
        }

        .navbar-brand-st {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .navbar-brand-icon {
            width: 32px;
            height: 32px;
            background: var(--burgundy);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--warm-white);
            font-size: 16px;
        }

        .navbar-brand-text {
            font-size: 17px;
            font-weight: 500;
            color: var(--burgundy-dark);
        }

        .nav-link-st {
            color: var(--slate-light);
            text-decoration: none;
            font-size: 14px;
            padding: 6px 12px;
            border-radius: 6px;
            transition: background 0.15s, color 0.15s;
        }

        .nav-link-st:hover {
            background: var(--cream);
            color: var(--slate);
        }

        .card-st {
            background: var(--warm-white);
            border: 0.5px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
        }

        .form-label-st {
            font-size: 13px;
            color: var(--slate-light);
            margin-bottom: 4px;
            display: block;
        }

        .form-control-st {
            width: 100%;
            padding: 8px 12px;
            font-size: 14px;
            color: var(--slate);
            background: var(--cream);
            border: 0.5px solid var(--border);
            border-radius: 8px;
            outline: none;
            transition: border-color 0.15s;
        }

        .form-control-st:focus {
            border-color: var(--burgundy-light);
        }

        .btn-primary-st {
            background: var(--burgundy);
            color: var(--warm-white);
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 14px;
            cursor: pointer;
            transition: background 0.15s;
            width: 100%;
        }

        .btn-primary-st:hover {
            background: var(--burgundy-light);
        }

        .btn-secondary-st {
            background: transparent;
            color: var(--slate);
            border: 0.5px solid var(--border);
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 14px;
            cursor: pointer;
            transition: background 0.15s;
        }

        .btn-secondary-st:hover {
            background: var(--cream);
        }

        .text-danger-st {
            font-size: 12px;
            color: #A32D2D;
            margin-top: 3px;
        }

        .page-title {
            font-size: 20px;
            font-weight: 500;
            color: var(--burgundy-dark);
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>
    <nav class="navbar-st d-flex align-items-center justify-content-between">
        <a class="navbar-brand-st" asp-controller="Home" asp-action="Index">
            <div class="navbar-brand-icon">
                <i class="ti ti-book-2" aria-hidden="true"></i>
            </div>
            <span class="navbar-brand-text">SoruTakip</span>
        </a>

        <div class="d-flex align-items-center gap-2">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="nav-link-st" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="nav-link-st" asp-controller="Question" asp-action="Index">Questions</a>
                <a class="nav-link-st" asp-controller="Folder" asp-action="Index">Folders</a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0;">
                    <button type="submit" class="nav-link-st" style="background: none; border: none; cursor: pointer;">Logout</button>
                </form>
            }
            else
            {
                <a class="nav-link-st" asp-controller="Account" asp-action="Login">Login</a>
                <a class="nav-link-st" asp-controller="Account" asp-action="Register">Register</a>
            }
        </div>
    </nav>

    <main style="padding: 2rem 1.5rem; max-width: 1100px; margin: 0 auto;">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>