@{
    ViewData["Title"] = "SoruTakip";
}

<div style="max-width: 560px; margin: 5rem auto; text-align: center;">
    <div style="width: 56px; height: 56px; background: var(--burgundy); border-radius: 14px;
                display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
        <i class="ti ti-book-2" style="font-size: 28px; color: var(--warm-white);" aria-hidden="true"></i>
    </div>

    <h1 style="font-size: 28px; font-weight: 500; color: var(--burgundy-dark); margin-bottom: 0.75rem;">
        SoruTakip
    </h1>

    <p style="font-size: 15px; color: var(--slate-light); margin-bottom: 2rem; line-height: 1.6;">
        Upload the questions you get stuck on, track your progress,<br>and never lose sight of what needs work.
    </p>

    <div style="display: flex; gap: 10px; justify-content: center;">
        <a asp-controller="Account" asp-action="Register" class="btn-primary-st"
           style="text-decoration: none; width: auto; padding: 10px 24px; font-size: 14px;">
            Get Started
        </a>
        <a asp-controller="Account" asp-action="Login" class="btn-secondary-st"
           style="text-decoration: none; padding: 10px 24px; font-size: 14px;">
            Login
        </a>
    </div>
</div>